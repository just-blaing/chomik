<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="chomik.MessageBox"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        PointerPressed="on_pointer_pressed"
        PointerMoved="on_pointer_moved"
        PointerReleased="on_pointer_released">
    <Border CornerRadius="12" Background="Black" BorderBrush="#9400d3" BorderThickness="2" MinWidth="260">
        <Grid RowDefinitions="*,Auto">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="20,18,20,18">
                <TextBlock x:Name="msg_text" Foreground="White" TextAlignment="Left"
                           HorizontalAlignment="Left" VerticalAlignment="Center"
                           FontSize="13" TextWrapping="Wrap" MaxWidth="200"/>
                <Image x:Name="anim_image" Grid.Column="1" Stretch="None"
                       HorizontalAlignment="Right" VerticalAlignment="Center"
                       Margin="14,0,0,0"/>
            </Grid>
            <Border Grid.Row="1" Background="#282828" Height="40" CornerRadius="0,0,12,12">
                <Button Content="ok" Click="on_ok_click" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="#282828" Foreground="White" BorderThickness="0" CornerRadius="4" Width="80"/>
            </Border>
        </Grid>
    </Border>
</Window>
