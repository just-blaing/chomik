<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="chomik.WriteDialog"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Width="300" Height="130"
        PointerPressed="on_pointer_pressed"
        PointerMoved="on_pointer_moved"
        PointerReleased="on_pointer_released">
    <Border CornerRadius="12" Background="Black" BorderBrush="#9400d3" BorderThickness="2">
        <Grid RowDefinitions="*,Auto">
            <StackPanel Grid.Row="0" Margin="14,12,14,4" Spacing="6">
                <TextBlock Text="что написать?" Foreground="#888888" FontSize="11"/>
                <TextBox x:Name="input_box" MaxLength="60"
                         Background="#1a1a1a" Foreground="White"
                         BorderBrush="#9400d3" BorderThickness="1"
                         CaretBrush="White" FontSize="13"
                         TextChanged="on_text_changed"
                         KeyDown="on_key_down"/>
                <TextBlock x:Name="counter_label" Text="0/60"
                           Foreground="#555555" FontSize="10"
                           HorizontalAlignment="Right"/>
            </StackPanel>
            <Border Grid.Row="1" Background="#282828" Height="40" CornerRadius="0,0,12,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            VerticalAlignment="Center" Spacing="10">
                    <Button Content="отмена" Click="on_cancel_click"
                            Background="#282828" Foreground="#888888"
                            BorderThickness="0" CornerRadius="4" Width="80"/>
                    <Button Content="ок" Click="on_ok_click"
                            Background="#282828" Foreground="White"
                            BorderThickness="0" CornerRadius="4" Width="80"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
